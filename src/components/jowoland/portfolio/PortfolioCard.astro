---
import type { PortfolioProject } from '@/lib/wordpress/types';

interface Props {
  project: PortfolioProject;
}

const { project } = Astro.props;
const image = project.image;

// Strip HTML tags for description preview
const stripHtml = (html: string) => {
  return html.replace(/<[^>]*>/g, '');
};
---

<a href="/contact" data-astro-prefetch class="group overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg  ">
  <div class="aspect-4/3 overflow-hidden">
    <img
      src={image}
      alt={project.imageAlt || project.name}
      class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-5">
    <h3
      class="font-bold text-neutral-800 group-hover:text-yellow-600 transition duration-300 "
    >
      {project.name}
    </h3>

    <div class="mt-3">
      {
        project.discountPrice ? (
          <div class="flex items-center gap-2">
            <span class="line-through text-neutral-400 text-sm">{project.price}</span>
            <span class="text-lg font-bold text-yellow-600 ">{project.discountPrice}</span>
            <span class="text-xs text-green-600 bg-green-100 px-2 py-0.5 rounded-full  ">Diskon</span>
          </div>
        ) : (
          project.price && (
            <span class="text-lg font-bold text-yellow-600 ">{project.price}</span>
          )
        )
      }
    </div>

    <p class="mt-3 text-sm text-neutral-600  line-clamp-3">
      {stripHtml(project.description)}
    </p>

    <dl class="mt-4 space-y-2">
      {
        project.location && (
          <div class="flex justify-between text-sm">
            <dt class="text-neutral-500 ">Lokasi:</dt>
            <dd class="font-medium text-neutral-800 ">{project.location}</dd>
          </div>
        )
      }
      {
        project.method && (
          <div class="flex justify-between text-sm">
            <dt class="text-neutral-500 ">Metode:</dt>
            <dd class="font-medium text-neutral-800 ">{project.method}</dd>
          </div>
        )
      }
      {
        project.diameter && (
          <div class="flex justify-between text-sm">
            <dt class="text-neutral-500 ">Diameter:</dt>
            <dd class="font-medium text-neutral-800 ">{project.diameter}</dd>
          </div>
        )
      }
      {
        project.depth && (
          <div class="flex justify-between text-sm">
            <dt class="text-neutral-500 ">Kedalaman:</dt>
            <dd class="font-medium text-neutral-800 ">{project.depth}</dd>
          </div>
        )
      }
      {
        project.points && (
          <div class="flex justify-between text-sm">
            <dt class="text-neutral-500 ">Jumlah Titik:</dt>
            <dd class="font-medium text-neutral-800 ">{project.points}</dd>
          </div>
        )
      }
    </dl>

    <div class="mt-4 flex items-center gap-2 font-semibold text-yellow-600">
      Konsultasi Gratis
      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>
