---
import { methodOptions } from '@/data/home/pricing-why';

const imageMap = {
  strauss: '/assets/img/beranda/metode-straus-pile.png',
  excavator: '/assets/img/beranda/metode-excavator.png',
};
---

<section
  id="metode"
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="mx-auto mb-10 max-w-3xl text-center">
    <h2
      class="text-2xl font-bold text-neutral-800 md:text-4xl "
    >
      {methodOptions.title}
    </h2>
    <p class="mt-3 text-neutral-600 ">
      {methodOptions.subtitle}
    </p>
  </div>

  <div class="grid gap-8 md:grid-cols-2">
    {
      methodOptions.methods.map(method => (
        <a href="/contact" data-astro-prefetch class="group overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg  ">
          <img
        src={imageMap[method.imageKey]}
        alt={method.title}
        class="h-auto w-full object-contain"
        loading="lazy"
      />
          <div class="p-6">
            <h3 class="text-xl font-bold text-neutral-800 group-hover:text-yellow-600 transition duration-300">
              {method.title}
            </h3>
            <p class="mt-2 text-neutral-600 ">
              {method.description}
            </p>
            <p class="mt-4 font-semibold text-yellow-600 flex items-center gap-2">
              Konsultasi Gratis 
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </p>
          </div>
        </a>
      ))
    }
  </div>
</section>
