---
import MainLayout from '@/layouts/MainLayout.astro';
import { getBlogPostBySlug } from '@/lib/wordpress/posts';
import { SITE, createWebPageSchema } from '@/data/site';

// Get slug from URL parameters
const { slug } = Astro.params;

// Get post data by slug
const post = slug ? await getBlogPostBySlug(slug) : null;

// Add error handling for undefined post or missing data
if (!post) {
  return Astro.redirect('/blog');
}

const formattedDate = post.date 
  ? new Date(post.date).toLocaleDateString('id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : 'Tanggal tidak diketahui';

const pageTitle = `${post.title || 'Blog Post'} | Blog | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  customDescription={post?.excerpt || 'Blog post'}
  customOgTitle={pageTitle}
  lang="id"
  structuredData={{
    ...createWebPageSchema(`/blog/${post?.slug || ''}`, post?.title || 'Blog Post', post?.excerpt || '', 'Article'),
    headline: post?.title || '',
    datePublished: post?.date || '',
    image: post?.image || '',
  }}
>
  <article
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <a
      href="/blog"
      class="mb-6 inline-flex items-center text-sm text-yellow-600 hover:underline "
    >
      ← Kembali ke Blog
    </a>

    <div class="mx-auto max-w-3xl">
      <time
        datetime={post?.date || ''}
        class="text-sm font-medium text-yellow-600 "
      >
        {formattedDate}
      </time>
      <h1
        class="mt-2 text-3xl font-bold text-neutral-800 md:text-4xl "
      >
        {post?.title || 'Blog Post'}
      </h1>

      {post?.image && (
        <div class="mt-8 overflow-hidden rounded-2xl">
          <img
            src={post.image}
            alt={post?.imageAlt || post?.title || 'Blog post image'}
            class="w-full object-cover"
            loading="eager"
          />
        </div>
      )}

      <div
        class="prose prose-neutral mt-10 max-w-none "
        set:html={post?.content || '<p>No content available.</p>'}
      />
    </div>
  </article>
</MainLayout>
