---
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

// Import necessary images
import straussImage from '@images/using-tools.avif';
import equipmentImage from '@images/automated-tools.avif';
import processImage from '@images/person-working.avif';
import { SITE } from '@data/site';

const pageTitle = `Jasa Strauss Pile | ${SITE.title}`;
const metaDescription = 'Layanan profesional jasa strauss pile untuk pondasi bangunan bertingkat rendah hingga menengah. Metode ekonomis dengan hasil optimal dan ramah lingkungan.';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={pageTitle}
  lang="id"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Jasa Strauss Pile',
    description: metaDescription,
    provider: {
      '@type': 'Organization',
      name: SITE.title,
    },
    areaServed: {
      '@type': 'Place',
      name: 'Indonesia',
    },
  }}
>

<MainSection
  title="Jasa Strauss Pile Terpercaya"
  subTitle="Solusi pondasi dalam yang ekonomis dan efektif untuk bangunan rumah tinggal, ruko, dan bangunan bertingkat rendah hingga menengah dengan metode strauss pile yang ramah lingkungan."
  btnExists={true}
  btnTitle="Konsultasi Gratis"
  btnURL="/contact"
/>

<LeftSection
  title="Apa itu Strauss Pile?"
  subTitle="Strauss pile adalah metode konstruksi pondasi dalam menggunakan sistem manual atau semi-otomatis. Metode ini cocok untuk bangunan bertingkat rendah hingga menengah dengan diameter yang lebih kecil dibanding bore pile, sehingga lebih ekonomis dan fleksibel."
  img={straussImage}
  imgAlt="Proses konstruksi strauss pile"
/>

<RightSection
  title="Mengapa Memilih Strauss Pile?"
  subTitle="Strauss pile menawarkan solusi pondasi yang cost-effective dengan kualitas yang dapat diandalkan. Cocok untuk area dengan akses terbatas, tidak menimbulkan getaran signifikan, dan dapat disesuaikan dengan kondisi tanah lokal dengan mudah."
  single={false}
  imgOne={equipmentImage}
  imgOneAlt="Peralatan strauss pile"
  imgTwo={processImage}
  imgTwoAlt="Proses pengeboran strauss pile"
/>

<LeftSection
  title="Aplikasi Strauss Pile"
  subTitle="Ideal untuk rumah tinggal 1-3 lantai, ruko, gudang, dan bangunan komersial kecil. Metode ini sangat efektif pada tanah lunak, area rawa, atau lokasi dengan muka air tanah tinggi. Fleksibilitas tinggi memungkinkan penyesuaian diameter dan kedalaman sesuai kebutuhan."
  img={processImage}
  imgAlt="Aplikasi strauss pile"
  btnExists={true}
  btnTitle="Lihat Portfolio"
  btnURL="/portfolio"
/>

<FeaturesStats
  title="Keunggulan Kami"
  subTitle="Sebagai specialist strauss pile, kami menghadirkan solusi pondasi yang tepat sasaran dengan harga kompetitif dan kualitas terjamin untuk kebutuhan konstruksi Anda."
  mainStatTitle="500+"
  mainStatSubTitle="Proyek strauss pile yang telah selesai"
  stats={[
    {
      stat: '10+',
      description: 'Tahun pengalaman',
    },
    {
      stat: '95%',
      description: 'Proyek selesai tepat waktu',
    },
    {
      stat: '30%',
      description: 'Lebih hemat dari metode lain',
    },
  ]}
/>

</MainLayout>